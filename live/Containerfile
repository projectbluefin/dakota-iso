# Dakota live ISO: environment image
#
# Build with:
#   podman build --build-arg TARGET=dakota-nvidia -t localhost/dakota-nvidia-live .
#   podman build --build-arg TARGET=dakota        -t localhost/dakota-live .
#
# TARGET selects the source image. Everything else — initramfs rebuild,
# live-user setup, installer config, flatpaks — is identical for both variants.
#
# Three-stage build:
#   1. ref          — source Dakota image (provides kernel modules)
#   2. initramfs-builder — Debian: builds a dmsquash-live initramfs against
#                          Dakota's kernel modules in its native glibc environment
#   3. final        — Dakota: receives the rebuilt initramfs + live-env setup
#
# Dakota is GNOME OS / freedesktop-sdk based — no package manager, no dracut.
# The initramfs is built in a separate Debian stage so no cross-distro binary
# grafting is needed; only the initramfs.img output crosses the stage boundary.

ARG TARGET=dakota-nvidia
# TAG selects the image tag. Defaults to 'stable'; use 'lts' for LTS variants.
ARG TAG=stable
# REGISTRY selects the OCI registry org. Defaults to projectbluefin.
ARG REGISTRY=projectbluefin

# ── Stage 1: Reference image (kernel modules source) ─────────────────────────
FROM ghcr.io/${REGISTRY}/${TARGET}:${TAG} AS ref

# ── Stage 2a: Native initramfs (for images that have dracut, e.g. Fedora/bluefin)
# If dracut is available on the target image, build the initramfs there so
# the udev rules, blkid, and cdrom_id all match the kernel. Falls back to
# the Debian cross-build stage (2b) for images that lack a package manager
# (e.g. GNOME OS / dakota).
FROM ref AS initramfs-native
RUN set -ex; \
    kernel=$(ls /usr/lib/modules | sort -V | tail -1); \
    if command -v dracut >/dev/null 2>&1 || command -v dnf >/dev/null 2>&1 || command -v rpm >/dev/null 2>&1; then \
        # Ensure dracut + dracut-live module are installed
        command -v dnf >/dev/null 2>&1 && \
            dnf install -y dracut dracut-live --setopt=install_weak_deps=False -q 2>/dev/null || true; \
        command -v dracut >/dev/null 2>&1 || { echo 'no dracut after install attempt'; touch /tmp/no-native-dracut; exit 0; }; \
        dracut --list-modules 2>/dev/null | grep -q dmsquash-live || { echo 'dmsquash-live module not found'; touch /tmp/no-native-dracut; exit 0; }; \
        echo "Building initramfs natively for kernel ${kernel}"; \
        dracut -v --force --reproducible --no-hostonly \
            --add "dmsquash-live" \
            /tmp/initramfs.img "${kernel}"; \
        ls -lh /tmp/initramfs.img; \
        echo native > /tmp/dracut-status; \
    else \
        echo "Target has no dracut/rpm — will use Debian cross-build"; \
        echo debian > /tmp/dracut-status; \
        touch /tmp/initramfs.img; \
    fi

# ── Stage 2b: Debian — cross-builds the initramfs for images without dracut ──
FROM debian:sid AS initramfs-builder

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        dracut \
        dmsetup \
        systemd-boot-efi \
        xfsprogs \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ref /usr/lib/modules /usr/lib/modules
COPY --from=initramfs-native /tmp/dracut-status /tmp/
COPY --from=initramfs-native /tmp/initramfs.img /tmp/native-initramfs/

RUN set -ex; \
    if grep -q debian /tmp/dracut-status 2>/dev/null; then \
        kernel=$(ls /usr/lib/modules | sort -V | tail -1); \
        echo "Cross-building initramfs (Debian dracut) for kernel ${kernel}"; \
        DRACUT_NO_XATTR=1 dracut -v --force --zstd --reproducible --no-hostonly \
            --add "dmsquash-live" \
            --add-drivers "squashfs overlay loop iso9660 sr_mod cdrom" \
            /tmp/initramfs.img "${kernel}"; \
    else \
        echo "Using native initramfs"; \
        cp /tmp/native-initramfs/initramfs.img /tmp/initramfs.img; \
    fi; \
    ls -lh /tmp/initramfs.img

# ── Stage 3: Final live image ─────────────────────────────────────────────────
ARG TARGET=dakota-nvidia
ARG TAG=stable
ARG REGISTRY=projectbluefin
FROM ghcr.io/${REGISTRY}/${TARGET}:${TAG}

ARG TARGET=dakota-nvidia
ARG TAG=stable
ARG REGISTRY=projectbluefin
ARG INSTALLER_CHANNEL=stable
ARG DEBUG=0
ENV TARGET=${TARGET} INSTALLER_CHANNEL=${INSTALLER_CHANNEL} DEBUG=${DEBUG}

COPY --from=initramfs-builder /tmp/initramfs.img /tmp/initramfs.img
# xfsprogs: copy mkfs.xfs so fisherman's preflight check passes on images
# (like GnomeOS/dakota) that don't ship xfsprogs by default. We changed the
# installer default to XFS which triggers the mkfs.xfs preflight check.
COPY --from=initramfs-builder /usr/sbin/mkfs.xfs /usr/sbin/mkfs.xfs
COPY --from=initramfs-builder /usr/sbin/xfs_repair /usr/sbin/xfs_repair
# Ensure systemd-boot EFI binary is present for the live ISO builder regardless
# of whether the target distro ships it (e.g. bluefin uses GRUB, not systemd-boot,
# so the binary is absent from the base image but still needed for the live ISO).
COPY --from=initramfs-builder /usr/lib/systemd/boot /usr/lib/systemd/boot
RUN kernel=$(ls /usr/lib/modules | sort -V | tail -1) && \
    mv /tmp/initramfs.img "/usr/lib/modules/${kernel}/initramfs.img" && \
    echo "Replaced initramfs for kernel ${kernel}"

COPY src/flatpaks /tmp/flatpaks-list
RUN --mount=type=bind,source=src,target=/src \
    --mount=type=cache,target=/var/cache/flatpak-dl,id=dakota-flatpak-${TARGET} \
    /src/install-flatpaks.sh

COPY src/ /tmp/src/
RUN chmod +x /tmp/src/configure-live.sh && /tmp/src/configure-live.sh
